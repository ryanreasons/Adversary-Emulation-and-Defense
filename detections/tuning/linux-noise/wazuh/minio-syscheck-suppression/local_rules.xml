<!-- Local rules -->
<group name="local,linux,syscheck,minio,tuning,">
  <!-- Ryan: Suppress MinIO internal FIM churn under /.minio.sys for recruiting-memory.
       Ryan: I am reducing alert fatigue while keeping syscheck/FIM enabled everywhere. -->

  <rule id="111550" level="0">
    <if_sid>550</if_sid>
    <match type="pcre2">/srv/data/cold/containers/recruiting-memory/budibase/data/minio/\.minio\.sys/</match>
    <description>Ryan: Suppressed MinIO syscheck checksum-change noise under /.minio.sys (recruiting-memory)</description>
    <group>syscheck,minio,noise,</group>
  </rule>

  <rule id="111553" level="0">
    <if_sid>553</if_sid>
    <match type="pcre2">/srv/data/cold/containers/recruiting-memory/budibase/data/minio/\.minio\.sys/</match>
    <description>Ryan: Suppressed MinIO syscheck delete noise under /.minio.sys (recruiting-memory)</description>
    <group>syscheck,minio,noise,</group>
  </rule>

  <rule id="111554" level="0">
    <if_sid>554</if_sid>
    <match type="pcre2">/srv/data/cold/containers/recruiting-memory/budibase/data/minio/\.minio\.sys/</match>
    <description>Ryan: Suppressed MinIO syscheck add noise under /.minio.sys (recruiting-memory)</description>
    <group>syscheck,minio,noise,</group>
  </rule>
</group>
